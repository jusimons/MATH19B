    {
      "cell_type": "code",
      "source": [
        "# Function to find the Nth partial sum of the power series solution to\n",
        "# y''+y=0, y(0) = 0, y'(0)=1\n",
        "def taylor_sine(x, N):\n",
        "    sinx = 0\n",
        "    for n in range(N):\n",
        "        sinx += ((-1)**n) * (x**(2*n+1)) / math.factorial(2*n+1)\n",
        "    return sinx\n",
        "\n",
        "# Define the range for x\n",
        "x_vals = np.linspace(-2*np.pi, 2*np.pi, 500)\n",
        "\n",
        "# ---------- Interactive UI ----------\n",
        "N_widget_sine = widgets.IntSlider(\n",
        "    value=1, min=1, max=20, step=1,\n",
        "    description=\"N terms:\",\n",
        "    continuous_update=False,\n",
        "    style={\"description_width\": \"initial\"},\n",
        ")\n",
        "\n",
        "sine_out = widgets.Output()\n",
        "\n",
        "def render_sine(_=None):\n",
        "    with sine_out:\n",
        "        sine_out.clear_output(wait=True)\n",
        "\n",
        "        N = N_widget_sine.value\n",
        "\n",
        "        # Calculate Taylor series approximation\n",
        "        taylor_approx = [taylor_sine(x, N) for x in x_vals]\n",
        "\n",
        "        plt.figure(figsize=(10, 6))\n",
        "        plt.plot(x_vals, np.sin(x_vals), label='sin(x)', color='blue')\n",
        "        plt.plot(x_vals, taylor_approx, label=f'Partial Sum of Power Series (N={N})', color='red', linestyle='--')\n",
        "        plt.title(f'Power Series Approximation for Solution to y\\\"+y=0$')\n",
        "        plt.xlabel('x')\n",
        "        plt.ylabel('y')\n",
        "        plt.grid(True)\n",
        "        plt.legend()\n",
        "        plt.ylim(-1.5, 1.5)\n",
        "        plt.show()\n",
        "\n",
        "N_widget_sine.observe(render_sine, names=\"value\")\n",
        "\n",
        "sine_controls = widgets.VBox([\n",
        "    N_widget_sine,\n",
        "])\n",
        "\n",
        "display(sine_controls, sine_out)\n",
        "render_sine()"
