      "source": [
        "#Define the trapezoid rule here:\n",
        "def trapezoid_rule(f, a, b, N):\n",
        "    x = np.linspace(a, b, N+1)\n",
        "    y = f(x)\n",
        "    dx = (b-a)/N\n",
        "    return dx*(0.5*y[0] + y[1:-1].sum() + 0.5*y[-1])\n",
        "\n",
        "# EDIT HERE: change a,b as needed\n",
        "a, b = 0.0, 1.0\n",
        "\n",
        "# Define our integrand\n",
        "f = lambda x: 1/((2*np.pi)**0.5)*np.exp((-x**2)/2)\n",
        "\n",
        "#Define P\n",
        "prob = trapezoid_rule(f, a, b, 300_000)  # high-resolution trap rule\n",
        "\n",
        "print('Probability between ', a, ' and ', b, ' is: ', prob)\n",
        "\n"
      ]
